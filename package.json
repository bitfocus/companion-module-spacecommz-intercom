{
	"name": "spacecommz-intercom",
	"version": "1.1.2",
	"main": "dist/main.js",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-spacecommz-intercom.git"
	},
	"engines": {
		"node": "^22.20",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "^1.8.0",
		"bufferutil": "^4.0.8",
		"companion-module-utils": "^0.5.0",
		"cors": "^2.8.5",
		"express": "^4.20.0",
		"socket.io": "^4.7.5",
		"utf-8-validate": "^6.0.4"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.6.1",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^22.19.3",
		"eslint": "^9.39.2",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.2",
		"prettier": "^3.7.4",
		"rimraf": "^6.1.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.51.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.12.0"
}
